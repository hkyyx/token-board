{
  "name": "token-board",
  "version": "0.1.0",
  "private": true,
  "description": "Track daily AI token usage across platforms and publish GitHub-style activity heatmaps",
  "bin": {
    "token-board": "./packages/cli/dist/index.js"
  },
  "workspaces": [
    "packages/*",
    "action"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.json && node -e \"require('fs').chmodSync('packages/cli/dist/index.js', 0o755)\"",
    "dev": "npm run build && node packages/cli/dist/index.js",
    "typecheck": "tsc -b"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
